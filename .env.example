# ─────────────────────────────────────────────────────────────
# EventOS — root docker-compose variables
# Copy to .env and adjust. These feed docker-compose.yml only.
# The Laravel app reads its OWN env at eventos-api/.env
# ─────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=eventos

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=eventos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Dual-role model for Row-Level Security (see README / architecture §4):
EVENTOS_MIGRATOR_PASSWORD=migrator_secret   # owns tables, BYPASSRLS, runs migrations/seeds
EVENTOS_APP_PASSWORD=app_secret             # runtime role, subject to RLS
PG_PORT=5433                                # host port (5432 is often taken by Laragon)

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6380                             # host port (6379 often taken)

# ── API / Nginx ──────────────────────────────────────────────
API_HTTP_PORT=8088   # 8080 is commonly taken (e.g. a local Java/Tomcat app)

# ── Reverb (WebSockets) ──────────────────────────────────────
REVERB_PORT=8081

# ── Mailpit (catch-all mail) ─────────────────────────────────
MAILPIT_UI_PORT=8025

# ── MinIO (S3-compatible object storage) ─────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=eventos
MINIO_ROOT_PASSWORD=eventos_secret
MINIO_BUCKET=eventos

# ── Meilisearch (opt-in: `--profile search`) ─────────────────
MEILI_PORT=7700
MEILI_MASTER_KEY=masterKey123456

# ── Adminer DB UI (opt-in: `--profile tools`) ────────────────
ADMINER_PORT=8090

# ── Nuxt SPAs ────────────────────────────────────────────────
ADMIN_PORT=3000
EVENT_PORT=3001
