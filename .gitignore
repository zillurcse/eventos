# ── Dependencies (live in Docker named volumes, never committed) ──
**/vendor/
**/node_modules/

# ── Environment ──
.env
**/.env
!**/.env.example

# ── Laravel runtime ──
eventos-api/storage/*.key
eventos-api/.phpunit.result.cache
eventos-api/public/storage
eventos-api/storage/logs/*.log

# ── Nuxt build output ──
**/.nuxt/
**/.output/
**/.data/
**/dist/

# ── Local-only compose override ──
docker-compose.override.yml

# ── Extracted docs / scratch ──
*_extracted.txt
*_extracted.md

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
