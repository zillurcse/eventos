APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Platform apex for per-event microsites (<subdomain>.<apex>), e.g. expouse.test.
# Drives config/eventos.php → domain.* (subdomain validation + public site).
PLATFORM_APEX=expouse.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Zoom Meeting SDK (embed zoom-hosted sessions in the event page)
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Agora (embed agora-hosted broadcast sessions in the event page).
# Organizers normally set this per event in Settings › Video; this is the
# platform-wide fallback. Both values are 32-char hex from console.agora.io —
# the certificate signs each viewer's token and must never reach the browser.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL=7200

# Jitsi (embed jitsi-hosted sessions in the event page).
# The default meet.jit.si only works for local dev: it will not start a room
# until an authenticated moderator joins, so real attendees are stuck on
# "waiting for a moderator". For production point JITSI_DOMAIN at your own
# Jitsi and set a signing key — the API then issues the session host a
# moderator JWT and attendees a guest JWT, and the room starts on its own.
#
#   JaaS (8x8.vc):  JITSI_APP_ID=vpaas-magic-cookie-…, JITSI_KID, JITSI_PRIVATE_KEY (RS256 PEM)
#   Self-hosted:    JITSI_APP_ID=<prosody app id>, JITSI_APP_SECRET (HS256)
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=
JITSI_APP_SECRET=
JITSI_KID=
JITSI_PRIVATE_KEY=
JITSI_TOKEN_TTL=7200
